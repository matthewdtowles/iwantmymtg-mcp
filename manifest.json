{
  "manifest_version": "0.3",
  "name": "iwantmymtg-mcp",
  "display_name": "I Want My MTG",
  "version": "0.3.1",
  "description": "Query Magic: The Gathering cards, sets, and prices and manage your I Want My MTG collection.",
  "author": {
    "name": "matthewdtowles",
    "url": "https://github.com/matthewdtowles"
  },
  "homepage": "https://iwantmymtg.net",
  "repository": {
    "type": "git",
    "url": "https://github.com/matthewdtowles/iwantmymtg-mcp"
  },
  "license": "MIT",
  "keywords": ["mcp", "magic-the-gathering", "mtg", "tcg", "collection"],
  "server": {
    "type": "node",
    "entry_point": "dist/index.js",
    "mcp_config": {
      "command": "node",
      "args": ["${__dirname}/dist/index.js"],
      "env": {
        "IWMM_API_KEY": "${user_config.api_key}"
      }
    }
  },
  "tools_generated": true,
  "user_config": {
    "api_key": {
      "type": "string",
      "title": "I Want My MTG API key",
      "description": "Optional. Starts with iwm_live_. Needed only for the inventory, transaction, portfolio, and price-alert tools. Create one at https://iwantmymtg.net/user/api-keys.",
      "sensitive": true,
      "required": false
    }
  }
}
